<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/teal_200</item>
    </style>

    <style name="AppTheme.Dialog" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    
    <style name="BottomSheetDialogTheme" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowNoTitle">true</item>
        
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">false</item>
        
        <item name="android:gravity">bottom</item>
        <item name="android:layout_gravity">bottom</item>
        
        <item name="android:windowAnimationStyle">@style/Animation.BottomDialog.Fast</item>
    </style>
    
    
    <style name="Animation.BottomDialog.Fast" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/slide_in_bottom_fast</item>
        <item name="android:windowExitAnimation">@anim/slide_out_bottom_fast</item>
    </style>
</resources>