<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/containerLayoutVertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF222222">

    <ImageView
        android:id="@+id/backgroundImageVertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.7" />

    

    <android.support.constraint.ConstraintLayout
        android:id="@+id/mainContentVertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="25dp"
        android:paddingEnd="25dp">

        <android.support.v7.widget.CardView
            android:id="@+id/albumCardVertical"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.5"
            app:layout_constraintBottom_toTopOf="@+id/songInfoContainer"
            app:layout_constraintWidth_percent="0.95">

            <ImageView
                android:id="@+id/albumCoverVertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music_note"
                android:background="@android:color/transparent" />
        </android.support.v7.widget.CardView>

        <android.support.constraint.ConstraintLayout
            android:id="@+id/songInfoContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="30dp"
            app:layout_constraintBottom_toTopOf="@+id/progressArea">

            <TextView
                android:id="@+id/songTitleVertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="未知"
                android:textColor="@android:color/white"
                android:textSize="21.84sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnRotateBack"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/artistNameVertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="歌手未知"
                android:textColor="#99FFFFFF"
                android:textSize="14.28sp"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:maxLines="1"
                app:layout_constraintTop_toBottomOf="@+id/songTitleVertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnRotateBack"
                android:layout_marginEnd="10dp" />

            
            <ImageView
                android:id="@+id/btnRotateBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_screen_rotate_back"
                android:tint="#CCFFFFFF"
                android:padding="2dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btnMenuVertical"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginEnd="12dp"/>

            
            <ImageView
                android:id="@+id/btnMenuVertical"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_more_vert"
                android:tint="#CCFFFFFF"
                android:padding="2dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </android.support.constraint.ConstraintLayout>

        <LinearLayout
            android:id="@+id/controlButtonsVertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="60dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/btnPrevVertical"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_skip_previous"
                android:tint="#FFFFFFFF" />

            <ImageView
                android:id="@+id/btnPlayPauseVertical"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_pause"
                android:tint="#FFFFFFFF"
                android:layout_marginStart="45dp"
                android:layout_marginEnd="45dp" />

            <ImageView
                android:id="@+id/btnNextVertical"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_skip_next"
                android:tint="#FFFFFFFF" />

        </LinearLayout>

        <android.support.constraint.ConstraintLayout
            android:id="@+id/progressArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            app:layout_constraintBottom_toTopOf="@+id/controlButtonsVertical">

            <SeekBar
                android:id="@+id/progressBarVertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1000"
                android:progress="0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:splitTrack="false"
                android:progressBackgroundTint="#33FFFFFF"
                android:progressTint="#FFFFFF"
                android:thumbTint="#FFFFFF"
                android:minHeight="18dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/timeCurrentVertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#88FFFFFF"
                android:textSize="13.2sp"
                android:layout_marginTop="5dp"
                android:layout_marginStart="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/progressBarVertical" />

            <TextView
                android:id="@+id/timeTotalVertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#88FFFFFF"
                android:textSize="13.2sp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/progressBarVertical" />

        </android.support.constraint.ConstraintLayout>

    </android.support.constraint.ConstraintLayout>

</android.support.constraint.ConstraintLayout>